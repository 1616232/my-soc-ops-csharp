@using SocOps.Models

<div class="flex flex-col min-h-full bg-mb-charcoal">
    <!-- Luxury Header -->
    <header class="flex items-center justify-between p-4 luxury-header">
        <button
            @onclick="OnReset"
            class="text-mb-platinum text-sm px-4 py-2 rounded transition-colors duration-300 hover:text-white hover:bg-mb-dark-gray">
            ← Back
        </button>
        <h1 class="font-bold text-2xl text-mb-platinum" style="font-family: 'Playfair Display', serif;">⭐ SOC OPS ⭐</h1>
        <div class="w-16"></div>
    </header>

    <!-- Brand Tagline -->
    <div class="text-center text-mb-silver text-xs py-1 px-4 italic opacity-70">
        The Best or Nothing
    </div>

    <!-- Instructions -->
    <p class="text-center text-mb-silver text-sm py-3 px-4 animate-page-reveal stagger-1">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo Celebration -->
    @if (HasBingo)
    {
        <div class="bg-gradient-to-r from-mb-dark-gray to-mb-charcoal text-mb-platinum text-center py-3 font-bold text-lg animate-bingo-reveal" style="font-family: 'Playfair Display', serif; border-top: 1px solid var(--mb-platinum); border-bottom: 1px solid var(--mb-platinum);">
            ⭐ BINGO! LINE COMPLETE ⭐
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-4 animate-page-reveal stagger-2">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
