@using SocOps.Models

<div class="relative animate-page-reveal">
    <!-- Three-Pointed Star Watermark -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-5 animate-star-pulse" style="font-size: 12rem; z-index: 0;">
        ★
    </div>
    
    <!-- Board Frame -->
    <div class="relative z-10 p-6 rounded-2xl metallic-border" style="background: linear-gradient(135deg, rgba(45, 45, 45, 0.8) 0%, rgba(26, 26, 26, 0.9) 100%); backdrop-filter: blur(10px);">
        <div class="grid grid-cols-5 gap-2 w-full max-w-md mx-auto aspect-square">
            @foreach (var square in Board)
            {
                <BingoSquare
                    Square="@square"
                    IsWinning="@WinningSquareIds.Contains(square.Id)"
                    OnClick="@(() => OnSquareClick.InvokeAsync(square.Id))" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }
}
